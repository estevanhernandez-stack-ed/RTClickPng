<?xml version="1.0" encoding="utf-8"?>
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap10="http://schemas.microsoft.com/appx/manifest/uap/windows10/10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  xmlns:desktop4="http://schemas.microsoft.com/appx/manifest/desktop/windows10/4"
  xmlns:desktop5="http://schemas.microsoft.com/appx/manifest/desktop/windows10/5"
  xmlns:com="http://schemas.microsoft.com/appx/manifest/com/windows10"
  IgnorableNamespaces="uap uap10 rescap desktop4 desktop5 com">

  <Identity
    Name="626LabsLLC.RightClicktoPNG"
    Publisher="CN=177BCE59-0966-4975-9962-10E36652141F"
    Version="0.1.0.0"
    ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>Right Click to PNG</DisplayName>
    <PublisherDisplayName>626Labs LLC</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop"
                        MinVersion="10.0.22621.0"
                        MaxVersionTested="10.0.26100.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-US" />
  </Resources>

  <Applications>
    <Application Id="App"
                 Executable="Settings\RTClickPng.Settings.exe"
                 EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="Right Click to PNG"
        Description="Convert images to PNG from the right-click context menu. No network calls, no detours."
        BackgroundColor="transparent"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png">
        <uap:DefaultTile Wide310x150Logo="Assets\Wide310x150Logo.png"
                         Square310x310Logo="Assets\Square310x310Logo.png"
                         ShortName="Right Click PNG" />
        <uap:SplashScreen Image="Assets\SplashScreen.png" />
      </uap:VisualElements>

      <Extensions>
        <!-- Four COM classes, one per verb.  ThreadingModel=STA because modern context menu hosts
             the extension in dllhost.exe (via SurrogateServer) using an STA apartment. -->
        <com:Extension Category="windows.comServer">
          <com:ComServer>
            <com:SurrogateServer DisplayName="Right Click PNG Shell Extension">
              <com:Class Id="68730B57-152E-4BC9-A158-3A03EE03465A"
                         Path="ShellExtension\ShellExtension.dll" ThreadingModel="STA" />
              <com:Class Id="D1407350-4611-4621-802E-475C82006858"
                         Path="ShellExtension\ShellExtension.dll" ThreadingModel="STA" />
              <com:Class Id="DC177957-7F24-486D-B4CB-D69FA4580C8F"
                         Path="ShellExtension\ShellExtension.dll" ThreadingModel="STA" />
              <com:Class Id="7C7F2F20-9F1E-4F0F-9FA8-D404369C2C07"
                         Path="ShellExtension\ShellExtension.dll" ThreadingModel="STA" />
              <com:Class Id="AB12D5C0-3E4F-4B1A-9E88-5C3D7F91AA01"
                         Path="ShellExtension\ShellExtension.dll" ThreadingModel="STA" />
            </com:SurrogateServer>
          </com:ComServer>
        </com:Extension>

        <!-- Register all four verbs against every supported source extension.  Per-verb visibility
             is decided at runtime by each IExplorerCommand::GetState using FileFilter + SettingsReader. -->
        <desktop4:Extension Category="windows.fileExplorerContextMenus">
          <desktop4:FileExplorerContextMenus>
            <desktop4:ItemType Type=".webp">
              <desktop4:Verb Id="ConvertToPng"  Clsid="68730B57-152E-4BC9-A158-3A03EE03465A" />
              <desktop4:Verb Id="CopyAsPng"     Clsid="D1407350-4611-4621-802E-475C82006858" />
              <desktop4:Verb Id="ConvertToJpeg" Clsid="DC177957-7F24-486D-B4CB-D69FA4580C8F" />
              <desktop4:Verb Id="CopyAsJpeg"    Clsid="7C7F2F20-9F1E-4F0F-9FA8-D404369C2C07" />
              <desktop4:Verb Id="Settings"      Clsid="AB12D5C0-3E4F-4B1A-9E88-5C3D7F91AA01" />
            </desktop4:ItemType>
            <desktop4:ItemType Type=".avif">
              <desktop4:Verb Id="ConvertToPng"  Clsid="68730B57-152E-4BC9-A158-3A03EE03465A" />
              <desktop4:Verb Id="CopyAsPng"     Clsid="D1407350-4611-4621-802E-475C82006858" />
              <desktop4:Verb Id="ConvertToJpeg" Clsid="DC177957-7F24-486D-B4CB-D69FA4580C8F" />
              <desktop4:Verb Id="CopyAsJpeg"    Clsid="7C7F2F20-9F1E-4F0F-9FA8-D404369C2C07" />
              <desktop4:Verb Id="Settings"      Clsid="AB12D5C0-3E4F-4B1A-9E88-5C3D7F91AA01" />
            </desktop4:ItemType>
            <desktop4:ItemType Type=".heic">
              <desktop4:Verb Id="ConvertToPng"  Clsid="68730B57-152E-4BC9-A158-3A03EE03465A" />
              <desktop4:Verb Id="CopyAsPng"     Clsid="D1407350-4611-4621-802E-475C82006858" />
              <desktop4:Verb Id="ConvertToJpeg" Clsid="DC177957-7F24-486D-B4CB-D69FA4580C8F" />
              <desktop4:Verb Id="CopyAsJpeg"    Clsid="7C7F2F20-9F1E-4F0F-9FA8-D404369C2C07" />
              <desktop4:Verb Id="Settings"      Clsid="AB12D5C0-3E4F-4B1A-9E88-5C3D7F91AA01" />
            </desktop4:ItemType>
            <desktop4:ItemType Type=".heif">
              <desktop4:Verb Id="ConvertToPng"  Clsid="68730B57-152E-4BC9-A158-3A03EE03465A" />
              <desktop4:Verb Id="CopyAsPng"     Clsid="D1407350-4611-4621-802E-475C82006858" />
              <desktop4:Verb Id="ConvertToJpeg" Clsid="DC177957-7F24-486D-B4CB-D69FA4580C8F" />
              <desktop4:Verb Id="CopyAsJpeg"    Clsid="7C7F2F20-9F1E-4F0F-9FA8-D404369C2C07" />
              <desktop4:Verb Id="Settings"      Clsid="AB12D5C0-3E4F-4B1A-9E88-5C3D7F91AA01" />
            </desktop4:ItemType>
            <desktop4:ItemType Type=".jpg">
              <desktop4:Verb Id="ConvertToPng"  Clsid="68730B57-152E-4BC9-A158-3A03EE03465A" />
              <desktop4:Verb Id="CopyAsPng"     Clsid="D1407350-4611-4621-802E-475C82006858" />
              <desktop4:Verb Id="ConvertToJpeg" Clsid="DC177957-7F24-486D-B4CB-D69FA4580C8F" />
              <desktop4:Verb Id="CopyAsJpeg"    Clsid="7C7F2F20-9F1E-4F0F-9FA8-D404369C2C07" />
              <desktop4:Verb Id="Settings"      Clsid="AB12D5C0-3E4F-4B1A-9E88-5C3D7F91AA01" />
            </desktop4:ItemType>
            <desktop4:ItemType Type=".jpeg">
              <desktop4:Verb Id="ConvertToPng"  Clsid="68730B57-152E-4BC9-A158-3A03EE03465A" />
              <desktop4:Verb Id="CopyAsPng"     Clsid="D1407350-4611-4621-802E-475C82006858" />
              <desktop4:Verb Id="ConvertToJpeg" Clsid="DC177957-7F24-486D-B4CB-D69FA4580C8F" />
              <desktop4:Verb Id="CopyAsJpeg"    Clsid="7C7F2F20-9F1E-4F0F-9FA8-D404369C2C07" />
              <desktop4:Verb Id="Settings"      Clsid="AB12D5C0-3E4F-4B1A-9E88-5C3D7F91AA01" />
            </desktop4:ItemType>
            <desktop4:ItemType Type=".png">
              <desktop4:Verb Id="ConvertToPng"  Clsid="68730B57-152E-4BC9-A158-3A03EE03465A" />
              <desktop4:Verb Id="CopyAsPng"     Clsid="D1407350-4611-4621-802E-475C82006858" />
              <desktop4:Verb Id="ConvertToJpeg" Clsid="DC177957-7F24-486D-B4CB-D69FA4580C8F" />
              <desktop4:Verb Id="CopyAsJpeg"    Clsid="7C7F2F20-9F1E-4F0F-9FA8-D404369C2C07" />
              <desktop4:Verb Id="Settings"      Clsid="AB12D5C0-3E4F-4B1A-9E88-5C3D7F91AA01" />
            </desktop4:ItemType>
            <desktop4:ItemType Type=".bmp">
              <desktop4:Verb Id="ConvertToPng"  Clsid="68730B57-152E-4BC9-A158-3A03EE03465A" />
              <desktop4:Verb Id="CopyAsPng"     Clsid="D1407350-4611-4621-802E-475C82006858" />
              <desktop4:Verb Id="ConvertToJpeg" Clsid="DC177957-7F24-486D-B4CB-D69FA4580C8F" />
              <desktop4:Verb Id="CopyAsJpeg"    Clsid="7C7F2F20-9F1E-4F0F-9FA8-D404369C2C07" />
              <desktop4:Verb Id="Settings"      Clsid="AB12D5C0-3E4F-4B1A-9E88-5C3D7F91AA01" />
            </desktop4:ItemType>
            <desktop4:ItemType Type=".tif">
              <desktop4:Verb Id="ConvertToPng"  Clsid="68730B57-152E-4BC9-A158-3A03EE03465A" />
              <desktop4:Verb Id="CopyAsPng"     Clsid="D1407350-4611-4621-802E-475C82006858" />
              <desktop4:Verb Id="ConvertToJpeg" Clsid="DC177957-7F24-486D-B4CB-D69FA4580C8F" />
              <desktop4:Verb Id="CopyAsJpeg"    Clsid="7C7F2F20-9F1E-4F0F-9FA8-D404369C2C07" />
              <desktop4:Verb Id="Settings"      Clsid="AB12D5C0-3E4F-4B1A-9E88-5C3D7F91AA01" />
            </desktop4:ItemType>
            <desktop4:ItemType Type=".tiff">
              <desktop4:Verb Id="ConvertToPng"  Clsid="68730B57-152E-4BC9-A158-3A03EE03465A" />
              <desktop4:Verb Id="CopyAsPng"     Clsid="D1407350-4611-4621-802E-475C82006858" />
              <desktop4:Verb Id="ConvertToJpeg" Clsid="DC177957-7F24-486D-B4CB-D69FA4580C8F" />
              <desktop4:Verb Id="CopyAsJpeg"    Clsid="7C7F2F20-9F1E-4F0F-9FA8-D404369C2C07" />
              <desktop4:Verb Id="Settings"      Clsid="AB12D5C0-3E4F-4B1A-9E88-5C3D7F91AA01" />
            </desktop4:ItemType>
            <desktop4:ItemType Type=".gif">
              <desktop4:Verb Id="ConvertToPng"  Clsid="68730B57-152E-4BC9-A158-3A03EE03465A" />
              <desktop4:Verb Id="CopyAsPng"     Clsid="D1407350-4611-4621-802E-475C82006858" />
              <desktop4:Verb Id="ConvertToJpeg" Clsid="DC177957-7F24-486D-B4CB-D69FA4580C8F" />
              <desktop4:Verb Id="CopyAsJpeg"    Clsid="7C7F2F20-9F1E-4F0F-9FA8-D404369C2C07" />
              <desktop4:Verb Id="Settings"      Clsid="AB12D5C0-3E4F-4B1A-9E88-5C3D7F91AA01" />
            </desktop4:ItemType>
          </desktop4:FileExplorerContextMenus>
        </desktop4:Extension>
      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>
</Package>
