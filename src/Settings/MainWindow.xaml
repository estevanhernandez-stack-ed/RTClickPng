<Window x:Class="RTClickPng.Settings.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Right Click PNG"
        Width="520" Height="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#0F1F31"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <LinearGradientBrush x:Key="BrandGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#17D4FA" Offset="0.0" />
            <GradientStop Color="#F22F89" Offset="1.0" />
        </LinearGradientBrush>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E6EBF3" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
        </Style>

        <!-- Custom toggle-switch-ish CheckBox: track + knob, cyan when on, gray when off. -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="48" Height="24" VerticalAlignment="Center">
                            <Border x:Name="Track"
                                    Background="#2A3649"
                                    CornerRadius="12"
                                    BorderThickness="1"
                                    BorderBrush="#3D4A5E" />
                            <Ellipse x:Name="Knob"
                                     Width="18" Height="18"
                                     HorizontalAlignment="Left"
                                     Margin="3,0,0,0"
                                     Fill="#E6EBF3" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#17D4FA" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="#17D4FA" />
                                <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Knob" Property="Margin" Value="0,0,3,0" />
                                <Setter TargetName="Knob" Property="Fill" Value="#0F1F31" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="BorderBrush" Value="#17D4FA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Right Click PNG"
                   FontSize="26"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource BrandGradient}"
                   Margin="0,0,0,2" />

        <TextBlock Grid.Row="1"
                   Text="Convert and copy images from the right-click menu."
                   FontSize="13"
                   Foreground="#8E9BAD"
                   Margin="0,0,0,20" />

        <Rectangle Grid.Row="2" Height="1" Fill="{StaticResource BrandGradient}" Opacity="0.6" Margin="0,0,0,20" />

        <StackPanel Grid.Row="3">
            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,24,0">
                    <TextBlock Text="Show JPEG variants" FontSize="14" FontWeight="SemiBold" />
                    <TextBlock Text="Add Convert to JPEG and Copy as JPEG to the right-click menu."
                               FontSize="12"
                               Foreground="#8E9BAD"
                               TextWrapping="Wrap"
                               Margin="0,3,0,0" />
                </StackPanel>
                <CheckBox Grid.Column="1"
                          x:Name="ShowJpegToggle"
                          Style="{StaticResource ToggleSwitch}"
                          VerticalAlignment="Center"
                          Click="OnShowJpegToggled" />
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,24,0">
                    <TextBlock Text="Confirm before overwriting" FontSize="14" FontWeight="SemiBold" />
                    <TextBlock Text="Prompt before replacing an existing file with the same name."
                               FontSize="12"
                               Foreground="#8E9BAD"
                               TextWrapping="Wrap"
                               Margin="0,3,0,0" />
                </StackPanel>
                <CheckBox Grid.Column="1"
                          x:Name="ConfirmOverwriteToggle"
                          Style="{StaticResource ToggleSwitch}"
                          VerticalAlignment="Center"
                          Click="OnConfirmOverwriteToggled" />
            </Grid>
        </StackPanel>

        <TextBlock Grid.Row="4"
                   Text="SETTINGS FILE"
                   FontFamily="Cascadia Mono, Consolas"
                   FontSize="10"
                   FontWeight="SemiBold"
                   Foreground="#5E6B7F"
                   Margin="0,20,0,4">
            <TextBlock.LayoutTransform>
                <ScaleTransform ScaleX="1.05" />
            </TextBlock.LayoutTransform>
        </TextBlock>

        <TextBlock Grid.Row="5"
                   x:Name="StatusText"
                   FontFamily="Cascadia Mono, Consolas"
                   FontSize="11"
                   Foreground="#8E9BAD"
                   TextTrimming="CharacterEllipsis" />
    </Grid>
</Window>
